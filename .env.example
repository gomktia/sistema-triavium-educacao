# Supabase PostgreSQL Connection String
# Encontre em: Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
# Conexão direta (sem pooling) — usada pelo Prisma para migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase API (para autenticação)
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Next.js public vars (expostas ao browser)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# URL pública da aplicação (usada em emails, convites, redirects)
NEXT_PUBLIC_APP_URL="https://triavium.com.br"

# Email transacional (Resend)
RESEND_API_KEY="re_xxxxxxxx"

# Vercel (gerenciamento de domínios personalizados)
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
